const CONTRACT_ADDRESS = import.meta.env.VITE_SEED_SECURE_ADDRESS?.trim();

if (!CONTRACT_ADDRESS) {
  console.error("[SeedSecure] FATAL: VITE_SEED_SECURE_ADDRESS is not defined in .env!");
}

// Debug: print contract address so it can be cross-referenced with the latest deployment
console.log("[SeedSecure] Using contract address:", CONTRACT_ADDRESS);

export async function verifyAndBurnPacket(childPacketId) {
  if (!childPacketId) {
    throw new Error("No QR code detected.");
  }

  if (!CONTRACT_ADDRESS) {
    throw new Error("Contract address not configured.");
  }

  if (!window.ethereum) {
    throw new Error("No crypto wallet found. Please install MetaMask.");
  }

  const batchesRef = collection(db, "batches");
  const q = query(batchesRef, where("childPacketIDs", "array-contains", childPacketId));
  const snapshot = await getDocs(q);

  if (snapshot.empty) {
    const error = new Error("This packet does not exist in the ledger.");
    error.reason = "NOT_FOUND";
    throw error;
  }

  const batchDoc = snapshot.docs[0];
  const data = batchDoc.data();

  // 1. Check if this specific child packet is already sold in Firebase
  const soldChildPackets = Array.isArray(data.soldChildPackets) ? data.soldChildPackets : [];
  if (soldChildPackets.includes(childPacketId)) {
    const error = new Error("This specific packet has already been sold and verified.");
    error.reason = "ALREADY_SOLD_FIREBASE";
    throw error;
  }

  // 2. DISPATCH GUARD: Reject batches that haven't left the factory yet
  const NOT_DISPATCHED_STATUSES = ["Ready", "Factory / Origin", "Pending", "PENDING"];
  if (NOT_DISPATCHED_STATUSES.includes(data.status)) {
    const error = new Error(
      "Error: This batch has not left the factory yet."
    );
    error.reason = "NOT_DISPATCHED";
    throw error;
  }

  // 3. Validate that the batch is in an appropriate state to be sold
  const VALID_SALE_STATUSES = ["At Retailer", "In Transit", "Ready for Sale", "Sold"];
  if (!VALID_SALE_STATUSES.includes(data.status)) {
    const error = new Error(`This batch has an unrecognised status ('${data.status}') and cannot be verified.`);
    error.reason = "INVALID_STATUS";
    throw error;
  }

  const rawBatchId = data.batchID;
  const cleanId = String(rawBatchId).replace(/\D/g, '');
  const numericId = BigInt(cleanId);

  console.log("[SeedSecure] Raw batchID from Firebase:", rawBatchId, "→ numeric:", numericId.toString());
  if (numericId === 0n) {
    const error = new Error('Failed to extract a valid numeric ID from the QR code.');
    error.reason = "UNINITIALIZED_BATCH";
    throw error;
  }

  const qrHash = ethers.keccak256(ethers.toUtf8Bytes(childPacketId));

  const cleanAddress = String(CONTRACT_ADDRESS).trim();
  if (!ethers.isAddress(cleanAddress)) {
    console.error('FAILED ADDRESS:', cleanAddress);
    throw new Error('Invalid Contract Address');
  }

  const provider = new ethers.BrowserProvider(window.ethereum, 80002);
  await provider.send("eth_requestAccounts", []);
  const signer = await provider.getSigner();
  await updateDoc(doc(db, "batches", batchDoc.id), {
    status: isLastPacket ? "Sold" : "At Retailer",
    lastLocation: "Verified Sold",
    soldAt: serverTimestamp(),
    soldChildPackets: arrayUnion(childPacketId),
  });

  return {
    success: true,
    txHash: receipt.hash,
    batchId,
    purityScore: data.purityScore,
    status: isLastPacket ? "Sold" : "At Retailer",
  };
}
