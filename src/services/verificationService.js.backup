/**
 * Extract the numeric batch ID from a QR string.
 * Handles formats like "BATCH_1772136175_PARENT_uuid" → "1772136175"
 * If the input is already purely numeric, returns it as-is.
 */
function extractNumericBatchId(raw) {
  const cleanId = String(raw).replace(/\D/g, '');
  return cleanId;
}

